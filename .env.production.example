# Production settings (do not commit real secrets)
APP_NAME="Event Logistics Swarm"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production

HOST=0.0.0.0
PORT=8080

DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/dbname
DATABASE_ECHO=False

REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

GOOGLE_API_KEY=change-me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2000

VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./chroma_db
PGVECTOR_ENABLED=False

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@eventlogistics.com
SMTP_FROM_NAME="Event Logistics Swarm"

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

CORS_ORIGINS=["https://swarm-frontend-1pt6c1hzt-humayun-23s-projects.vercel.app"]

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
